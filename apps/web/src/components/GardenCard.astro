---
import type { CollectionEntry } from 'astro:content';
import TagList from './TagList.astro';

export interface Props {
  post: CollectionEntry<'garden'>;
}

const { post } = Astro.props;
const { title, pubDate, tags } = post.data;
const date = new Date(pubDate).toLocaleDateString('pt-BR', {
  year: 'numeric',
  month: 'short',
  day: '2-digit',
});
---

<a href={`/garden/${post.id}/`} class="entry">
  <div class="entry-row">
    <span class="entry-title">{title}</span>
    <time class="entry-date" datetime={pubDate.toISOString()}>{date}</time>
  </div>
  <TagList tags={tags} />
</a>

<style>
  .entry {
    display: block;
    padding: var(--space-5) 0;
    border-top: 1px solid var(--color-border);
    text-decoration: none;
    color: inherit;
  }

  .entry-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-4);
  }

  .entry-title {
    font-family: var(--font-mono);
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .entry:hover .entry-title {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .entry-date {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-secondary);
    white-space: nowrap;
    font-variant-numeric: tabular-nums;
  }
</style>
