---
import { getCollection, render } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import Layout from '../../layouts/Layout.astro';
import ReadingTime from '../../components/ReadingTime.astro';
import TagList from '../../components/TagList.astro';
import RelatedLinks from '../../components/RelatedLinks.astro';
import ViewCount from '../../components/ViewCount.astro';

export const getStaticPaths = (async () => {
  const posts = await getCollection('garden');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}) satisfies GetStaticPaths;

const { post } = Astro.props;
const { Content } = await render(post);

const { title, pubDate, updatedDate, tags, related } = post.data;
const words = post.body?.split(/\s+/).length ?? 0;

const pubDateFormatted = new Date(pubDate).toLocaleDateString('pt-BR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const updatedDateFormatted = updatedDate
  ? new Date(updatedDate).toLocaleDateString('pt-BR', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : null;
---

<Layout title={`${title} — Garden`} description={title}>
  <main class="container">
    <article class="post">
      <header class="post-header">
        <h1 class="post-title">{title}</h1>
        <div class="post-meta">
          <time datetime={pubDate.toISOString()}>{pubDateFormatted}</time>
          <span class="meta-separator">·</span>
          <ReadingTime words={words} />
          <span class="meta-separator">·</span>
          <ViewCount slug={post.id} />
          {updatedDate && updatedDateFormatted && (
            <>
              <span class="meta-separator">·</span>
              <span class="updated-label">
                Atualizado em <time datetime={updatedDate.toISOString()}>{updatedDateFormatted}</time>
              </span>
            </>
          )}
        </div>
        <TagList tags={tags} />
      </header>

      <div class="post-body prose">
        <Content />
      </div>

      <RelatedLinks links={related} />
    </article>
  </main>
</Layout>

<style>
  .container {
    max-width: 42rem;
    margin: 0 auto;
    padding: 6.5rem var(--space-4) var(--space-16);
  }

  .post-header {
    margin-bottom: var(--space-10);
    padding-bottom: var(--space-6);
    border-bottom: 1px solid var(--color-border);
  }

  .post-title {
    font-size: 1.75rem;
    font-weight: 400;
    line-height: 1.3;
    margin-bottom: var(--space-4);
    color: var(--color-text);
    text-wrap: balance;
  }

  .post-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-4);
  }

  .meta-separator {
    opacity: 0.5;
  }

  .updated-label {
    font-style: italic;
  }

  .post-body {
    margin-bottom: var(--space-10);
  }
</style>
